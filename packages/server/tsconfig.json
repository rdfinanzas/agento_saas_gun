{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext"],
    "types": ["bun-types"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@db/*": ["./src/db/*"],
      "@services/*": ["./src/services/*"],
      "@routes/*": ["./src/routes/*"],
      "@middleware/*": ["./src/middleware/*"],
      "@utils/*": ["./src/utils/*"],
      "@types/*": ["./src/types/*"],

      "@opencode-ai/util/*": ["./src/lib/opencode/packages/util/src/*"],
      "@opencode-ai/plugin/*": ["./src/lib/opencode/packages/plugin/src/*"],
      "@opencode-ai/sdk/*": ["./src/lib/opencode/packages/sdk/src/*"],
      "@opencode-ai/script/*": ["./src/lib/opencode/packages/script/src/*"],

      "@/lib/opencode/*": ["./src/lib/opencode/*"],

      "@/account": ["./src/lib/opencode/stubs/account.ts"],
      "@/account/*": ["./src/lib/opencode/stubs/account.ts"],
      "@/agent/agent": ["./src/lib/opencode/agent/agent.ts"],
      "@/agent/*": ["./src/lib/opencode/agent/*"],
      "@/auth": ["./src/lib/opencode/auth/index.ts"],
      "@/auth/service": ["./src/lib/opencode/auth/service.ts"],
      "@/auth/*": ["./src/lib/opencode/auth/*"],
      "@/bun": ["./src/lib/opencode/stubs/bun.ts"],
      "@/bun/registry": ["./src/lib/opencode/stubs/bun-registry.ts"],
      "@/bun/*": ["./src/lib/opencode/stubs/bun.ts"],
      "@/bus": ["./src/lib/opencode/bus/index.ts"],
      "@/bus/bus-event": ["./src/lib/opencode/bus/bus-event.ts"],
      "@/bus/global": ["./src/lib/opencode/bus/global.ts"],
      "@/bus/*": ["./src/lib/opencode/bus/*"],
      "@/cli/cmd/*": ["./src/lib/opencode/cli/cmd/*"],
      "@/cli/*": ["./src/lib/opencode/cli/*"],
      "@/config/config": ["./src/lib/opencode/config/config.ts"],
      "@/config/*": ["./src/lib/opencode/config/*"],
      "@/control-plane/schema": ["./src/lib/opencode/control-plane/schema.ts"],
      "@/control-plane/workspace-context": ["./src/lib/opencode/control-plane/workspace-context.ts"],
      "@/control-plane/*": ["./src/lib/opencode/control-plane/*"],
      "@/effect/runtime": ["./src/lib/opencode/effect/runtime.ts"],
      "@/effect/*": ["./src/lib/opencode/effect/*"],
      "@/env/*": ["./src/lib/opencode/env/*"],
      "@/file/watcher": ["./src/lib/opencode/stubs/watcher.ts"],
      "@/file/*": ["./src/lib/opencode/file/*"],
      "@/flag/flag": ["./src/lib/opencode/flag/flag.ts"],
      "@/flag/*": ["./src/lib/opencode/flag/*"],
      "@/format/*": ["./src/lib/opencode/format/*"],
      "@/global": ["./src/lib/opencode/global/index.ts"],
      "@/global/*": ["./src/lib/opencode/global/*"],
      "@/id/id": ["./src/lib/opencode/id/id.ts"],
      "@/id/*": ["./src/lib/opencode/id/*"],
      "@/installation": ["./src/lib/opencode/installation/index.ts"],
      "@/installation/*": ["./src/lib/opencode/installation/*"],
      "@/lsp/*": ["./src/lib/opencode/lsp/*"],
      "@/mcp/*": ["./src/lib/opencode/mcp/*"],
      "@/patch/*": ["./src/lib/opencode/patch/*"],
      "@/permission/next": ["./src/lib/opencode/permission/next.ts"],
      "@/permission/*": ["./src/lib/opencode/permission/*"],
      "@/plugin": ["./src/lib/opencode/plugin/index.ts"],
      "@/plugin/*": ["./src/lib/opencode/plugin/*"],
      "@/project/instance": ["./src/lib/opencode/project/instance.ts"],
      "@/project/project": ["./src/lib/opencode/project/project.ts"],
      "@/project/*": ["./src/lib/opencode/project/*"],
      "@/provider/*": ["./src/lib/opencode/provider/*"],
      "@/question/*": ["./src/lib/opencode/question/*"],
      "@/scheduler/*": ["./src/lib/opencode/scheduler/*"],
      "@/server/*": ["./src/lib/opencode/server/*"],
      "@/session": ["./src/lib/opencode/session/index.ts"],
      "@/session/prompt": ["./src/lib/opencode/session/prompt.ts"],
      "@/session/*": ["./src/lib/opencode/session/*"],
      "@/share/*": ["./src/lib/opencode/share/*"],
      "@/shell/*": ["./src/lib/opencode/shell/*"],
      "@/skill/*": ["./src/lib/opencode/skill/*"],
      "@/snapshot/*": ["./src/lib/opencode/snapshot/*"],
      "@/storage/db": ["./src/lib/opencode/storage/db.ts"],
      "@/storage/storage": ["./src/lib/opencode/storage/storage.ts"],
      "@/storage/*": ["./src/lib/opencode/storage/*"],
      "@/tool/task": ["./src/lib/opencode/tool/task.ts"],
      "@/tool/tool": ["./src/lib/opencode/tool/tool.ts"],
      "@/tool/truncation": ["./src/lib/opencode/tool/truncation.ts"],
      "@/tool/*": ["./src/lib/opencode/tool/*"],
      "@/util/log": ["./src/lib/opencode/util/log.ts"],
      "@/util/proxied": ["./src/lib/opencode/util/proxied.ts"],
      "@/util/iife": ["./src/lib/opencode/util/iife.ts"],
      "@/util/filesystem": ["./src/lib/opencode/util/filesystem.ts"],
      "@/util/process": ["./src/lib/opencode/util/process.ts"],
      "@/util/lock": ["./src/lib/opencode/util/lock.ts"],
      "@/util/*": ["./src/lib/opencode/util/*"],
      "@/worktree": ["./src/lib/opencode/worktree/index.ts"],
      "@/worktree/*": ["./src/lib/opencode/worktree/*"]
    },
    "outDir": "./dist"
  },
  "include": ["src/**/*", "tests/**/*"],
  "exclude": ["node_modules", "dist"]
}

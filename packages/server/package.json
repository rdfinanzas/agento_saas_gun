{
  "name": "@agento/server",
  "version": "1.0.0",
  "type": "module",
  "description": "AgenTo Backend - Bun + Hono + Drizzle + PostgreSQL",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun --external 'mock-aws-s3' --external 'aws-sdk' --external 'nock' --external '@mapbox/node-pre-gyp'",
    "start": "bun run dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:drop": "drizzle-kit drop",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "test:e2e": "bun test tests/e2e/",
    "test:regression": "bun run tests/regression/run-regression.ts",
    "test:record": "bun run tests/regression/recorder/record-flows.ts",
    "test:replay": "bun run tests/regression/player/replay-all.ts",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.0.0",
    "@ai-sdk/amazon-bedrock": "^1.0.0",
    "@ai-sdk/anthropic": "^1.0.0",
    "@ai-sdk/azure": "^1.0.0",
    "@ai-sdk/cohere": "^1.0.0",
    "@ai-sdk/google": "^1.0.0",
    "@ai-sdk/google-vertex": "^1.0.0",
    "@ai-sdk/groq": "^1.0.0",
    "@ai-sdk/mistral": "^1.0.0",
    "@ai-sdk/openai": "^1.0.0",
    "@ai-sdk/perplexity": "^1.0.0",
    "@ai-sdk/xai": "^1.0.0",
    "@hono/zod-validator": "^0.4.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "ai": "^3.0.0",
    "axios": "^1.7.0",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.71.0",
    "chokidar": "^5.0.0",
    "decimal.js": "^10.6.0",
    "diff": "^9.0.0",
    "drizzle-orm": "^0.36.0",
    "effect": "^3.20.0",
    "eventemitter3": "^5.0.1",
    "fuzzysort": "^3.1.0",
    "hono": "^4.6.0",
    "ignore": "^7.0.5",
    "ioredis": "^5.4.0",
    "jsonc-parser": "^3.3.1",
    "jsonwebtoken": "^9.0.0",
    "mime-types": "^3.0.2",
    "open": "^11.0.0",
    "postgres": "^3.4.0",
    "remeda": "^2.33.6",
    "semver": "^7.7.4",
    "strip-ansi": "^7.2.0",
    "tree-sitter-bash": "^0.25.1",
    "turndown": "^7.2.2",
    "ulid": "^3.0.2",
    "uuid": "^10.0.0",
    "vscode-jsonrpc": "^8.2.1",
    "which": "^6.0.1",
    "yargs": "^17.7.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.28.0",
    "typescript": "^5.8.0",
    "@playwright/test": "^1.51.0",
    "playwright": "^1.51.0"
  },
  "exports": {
    ".": "./src/index.ts"
  }
}

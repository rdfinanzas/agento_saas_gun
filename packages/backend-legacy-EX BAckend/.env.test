# ===========================================
# Test Environment Configuration
# ===========================================
# This file is used for running tests

NODE_ENV=test

# ===========================================
# Database (Use a separate test database!)
# ===========================================
DATABASE_URL="postgresql://postgres:password@localhost:5432/agento_test"

# ===========================================
# Redis
# ===========================================
REDIS_URL="redis://localhost:6379"

# ===========================================
# JWT
# ===========================================
JWT_SECRET="test-secret-key-for-testing-minimum-32-characters-long"

# ===========================================
# AI Providers (Optional - for integration tests)
# ===========================================
# OPENAI_API_KEY=""
# ANTHROPIC_API_KEY=""
# GOOGLE_API_KEY=""

# ===========================================
# MercadoPago (Use sandbox credentials)
# ===========================================
MERCADOPAGO_ACCESS_TOKEN="TEST-xxxxx"
MERCADOPAGO_SANDBOX="true"

# ===========================================
# Server
# ===========================================
PORT=3001
BASE_URL="http://localhost:3001"
FRONTEND_URL="http://localhost:3000"
